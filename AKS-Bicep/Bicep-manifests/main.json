                  "loadBalancerSku": "standard",
                  "networkPlugin": "azure",
                  "serviceCidr": "[parameters('aksServiceCidr')]"
                },
                "nodeResourceGroup": "[variables('nodeResourceGroupName')]",
                "oidcIssuerProfile": {
                  "enabled": true
                },
                "supportPlan": "KubernetesOfficial",
