          "variables": {
            "environmentSlug": "[toLower(parameters('environment'))]",
            "locationSlug": "[toLower(replace(parameters('location'), ' ', ''))]",
            "envNoDash": "[replace(variables('environmentSlug'), '-', '')]",
            "nodePoolEnvironmentTag": "[if(greaterOrEquals(length(variables('envNoDash')), 3), substring(variables('envNoDash'), 0, 3), variables('envNoDash'))]",
            "windowsNodePoolTag": "[if(greaterOrEquals(length(variables('envNoDash')), 2), substring(variables('envNoDash'), 0, 2), variables('envNoDash'))]",
            "nameSuffix": "[format('{0}-aks-{1}-{2}', parameters('organizationName'), variables('environmentSlug'), variables('locationSlug'))]",
            "clusterSuffix": "[format('{0}-{1}-{2}', parameters('organizationName'), variables('environmentSlug'), variables('locationSlug'))]",
            "clusterName": "[format('aks-{0}', variables('clusterSuffix'))]",
            "nodeResourceGroupName": "[format('rg-{0}-nodes', variables('nameSuffix'))]",
            "logAnalyticsWorkspaceName": "[format('log-{0}', variables('nameSuffix'))]",
            "virtualNetworkName": "[format('vnet-{0}', variables('nameSuffix'))]",
            "systemSubnetName": "[format('snet-{0}-system', variables('nameSuffix'))]",
            "linuxUserSubnetName": "[format('snet-{0}-linux', variables('nameSuffix'))]",
            "windowsUserSubnetName": "[format('snet-{0}-windows', variables('nameSuffix'))]",
            "systemNodePoolNameBase": "[format('sys{0}01', variables('nodePoolEnvironmentTag'))]",
            "linuxUserNodePoolNameBase": "[format('lin{0}01', variables('nodePoolEnvironmentTag'))]",
            "windowsUserNodePoolNameBase": "[format('win{0}1', variables('windowsNodePoolTag'))]",
            "systemNodePoolName": "[substring(variables('systemNodePoolNameBase'), 0, min(length(variables('systemNodePoolNameBase')), 8))]",
            "linuxUserNodePoolName": "[substring(variables('linuxUserNodePoolNameBase'), 0, min(length(variables('linuxUserNodePoolNameBase')), 8))]",
            "windowsUserNodePoolName": "[substring(variables('windowsUserNodePoolNameBase'), 0, min(length(variables('windowsUserNodePoolNameBase')), 6))]",
            "commonTags": "[union(createObject('environment', parameters('environment'), 'managed_by', 'bicep', 'owner', parameters('organizationName'), 'platform', 'aks', 'project', 'aks-bicep'), parameters('additionalTags'))]",
            "systemNodePoolLabels": {
              "environment": "[parameters('environment')]",
              "nodepool-os": "linux",
              "nodepool-type": "system",
