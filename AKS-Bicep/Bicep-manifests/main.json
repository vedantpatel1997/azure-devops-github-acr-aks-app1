                "count": 1,
                "enableAutoScaling": true,
                "maxCount": 3,
                "minCount": 1,
                "mode": "User",
                "nodeLabels": "[variables('windowsUserNodePoolLabels')]",
                "orchestratorVersion": "[parameters('kubernetesVersion')]",
                "osDiskSizeGB": 50,
                "osSKU": "Windows2022",
                "osType": "Windows",
                "scaleSetPriority": "Regular",
                "tags": "[variables('windowsUserNodePoolTags')]",
                "type": "VirtualMachineScaleSets",
                "upgradeSettings": {
